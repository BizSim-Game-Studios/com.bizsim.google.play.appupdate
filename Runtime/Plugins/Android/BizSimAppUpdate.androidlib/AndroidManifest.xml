<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    package="com.bizsim.google.play.appupdate">

    <!-- C5.2 predictive back gesture (Android 14+ / API 34+).
         Play Core's flexible + immediate update flows render system-managed
         Activities that handle predictive-back animations internally
         (Play Core 2.1.0+, May 2023). Declared explicitly per
         2026-04-17-enterprise-quality-bar 06-conventions/05-predictive-back-audit.md.
         Consumer app-level android:enableOnBackInvokedCallback wins on
         manifest-merger conflict — this is package-level intent. -->
    <application
        android:enableOnBackInvokedCallback="true"
        tools:targetApi="33" />

</manifest>
